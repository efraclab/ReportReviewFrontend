# Server
PORT=4000
CORS_ORIGIN=http://localhost:5173

# MS SQL Server connection
SQL_SERVER=localhost
SQL_PORT=1433
SQL_DATABASE=LimsReview
SQL_USER=sa
SQL_PASSWORD=YourStrongPassword!
# Set to true if your SQL server requires TLS
SQL_ENCRYPT=false
# Set to false if you have a real certificate
SQL_TRUST_SERVER_CERTIFICATE=true

# File storage root (absolute or relative to backend/)
# PDFs land in <FILE_STORAGE_ROOT>/reviews/<reviewId>/<documentId>.pdf
FILE_STORAGE_ROOT=./storage

# Upload limits
MAX_FILE_SIZE_MB=32
MAX_FILES_PER_REVIEW=10
